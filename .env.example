# Copy to .env for local dev. On Render, set these in the dashboard / Blueprint.

# API key servercrm must send as the x-api-key header. Use a long random secret.
API_KEY=

# WEX Community (Salesforce) scraper login — same account servercrm uses.
WEX_USERNAME_SCRAPER=
WEX_PASSWORD_SCRAPER=

# Salesforce auth (resolves appId → record id / status / owner via SOQL).
SF_WEX_CLIENT_KEY=
SF_WEX_CLIENT_SECRET=
SF_WEX_USER=
SF_WEX_USER_PASSWORD=
SF_WEX_SECURITY_CODE=
WEX_SF_AUTH_URL=https://login.salesforce.com/services/oauth2/token

# Local dev only. On Render, PORT is injected automatically.
PORT=3000

# Durable metrics (optional). If unset, metrics are in-memory (reset on restart).
# On Render: create a Postgres, then set this to its INTERNAL Database URL and add
# PGSSL=disable (internal traffic stays on Render's private network — no TLS needed).
# For an EXTERNAL URL instead, omit PGSSL and provide DATABASE_CA_CERT (verified TLS).
# DATABASE_URL=
# PGSSL=disable
# DATABASE_CA_CERT=

# Optional SSRF allowlist for generic ops (screenshot/pdf/extract). Comma-separated
# domains; subdomains allowed. If unset, any public host is allowed but private/
# internal/loopback/metadata addresses are blocked via DNS resolution.
# AUTOMATION_URL_ALLOWLIST=example.com,wexinc.my.site.com

# Optional: opt in to Browserless instead of local Chromium (not needed — Docker
# image bundles Chromium). USE_BROWSERLESS=true + BROWSERLESS_API_KEY to enable.
# USE_BROWSERLESS=
# BROWSERLESS_API_KEY=
